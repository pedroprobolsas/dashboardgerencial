# ══════════════════════════════════════════════════════════════════════════════
#  .env.production — Dashboard Gerencial Probolsas
#  Copiar como backend/.env en el servidor y completar con valores reales.
#  ⚠️  NUNCA subir este archivo con valores reales a git.
# ══════════════════════════════════════════════════════════════════════════════

# ── Google Service Account ────────────────────────────────────────────────────
# Email de la cuenta de servicio creada en Google Cloud Console.
# La hoja debe estar compartida con este email (Editor).
GOOGLE_SERVICE_ACCOUNT_EMAIL=tu-cuenta@proyecto.iam.gserviceaccount.com

# Clave privada RSA de la cuenta de servicio.
# Copiar el campo "private_key" del JSON de Google Cloud completo,
# incluyendo encabezado y pie. Los saltos de línea deben ser \n literales.
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMIIE...(tu clave)...\n-----END PRIVATE KEY-----\n"

# ── Google Sheets — IDs de las hojas de cálculo ───────────────────────────────
# El ID está en la URL: docs.google.com/spreadsheets/d/<SPREADSHEET_ID>/edit
#
# Hoja 1 — Operativa (Facturacion_OP, IngresoLiquidacion, OrdenesProduccion,
#           Metas_Gerencia, Cierre_Ventas, Cierre_Finanzas, Cierre_Produccion,
#           Cierre_TalentoHumano, Informes_cierre_mensual)
SPREADSHEET_ID_1=ID_de_la_hoja_operativa

# Hoja 2 — Cartera y egresos (Cartera_Clientes, Base Exenta, Cierre_Cartera)
SPREADSHEET_ID_2=ID_de_la_hoja_cartera_egresos

# ── Umbrales de alerta (respaldo si la hoja Metas_Gerencia no tiene el valor) ──

# Meta de ventas mensual en COP (sin puntos ni comas — ej: 450000000 = $450M)
META_VENTAS=450000000

# % de cumplimiento de meta de ventas
META_VENTAS_PCT_VERDE=90
META_VENTAS_PCT_AMARILLO=80

# Margen bruto — porcentaje mínimo (ej: 35 = 35%)
META_MARGEN_VERDE=35
META_MARGEN_AMARILLO=25

# Cartera vencida — monto máximo aceptable en COP
META_CARTERA_VERDE=30000000
META_CARTERA_AMARILLO=50000000

# Flujo de caja — mínimo positivo en COP
META_FLUJO_VERDE=5000000

# % de cierres mensuales completados
META_CIERRE_VERDE=100
META_CIERRE_AMARILLO=60

# ── Servidor ──────────────────────────────────────────────────────────────────
PORT=3001

# ── CORS — orígenes permitidos (separados por coma) ──────────────────────────
# En producción: el dominio de Traefik. En desarrollo: localhost.
CORS_ORIGINS=https://ippgerencia.probolsas.co
