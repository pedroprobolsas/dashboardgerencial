# Copia este archivo como .env y completa los valores reales
# Nunca subas .env a git

GOOGLE_SERVICE_ACCOUNT_EMAIL=tu-service-account@proyecto.iam.gserviceaccount.com
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

SPREADSHEET_ID_1=ID_del_spreadsheet_1
SPREADSHEET_ID_2=ID_del_spreadsheet_2

# Metas por defecto (respaldo si la clave no existe en la hoja Metas_Gerencia)
META_VENTAS=200000000
META_VENTAS_PCT_VERDE=90
META_VENTAS_PCT_AMARILLO=80
META_MARGEN_VERDE=35
META_MARGEN_AMARILLO=25
META_CARTERA_VERDE=30000000
META_CARTERA_AMARILLO=50000000
META_FLUJO_VERDE=5000000
META_CIERRE_VERDE=100
META_CIERRE_AMARILLO=60

PORT=3001

# ── PostgreSQL — probolsas_db (red Docker: postgres_postgres) ─────────────────
PG_HOST=postgres_postgres
PG_PORT=5432
PG_DATABASE=probolsas_db
PG_USER=probolsas_user
PG_PASSWORD=tu_password_aqui

# Alternativa: cadena completa (tiene precedencia si PG_HOST no está definido)
DATABASE_URL=postgresql://probolsas_user:tu_password_aqui@postgres_postgres:5432/probolsas_db

# ── Feature flags — migración módulo a módulo ──────────────────────────────────
# Valores válidos: "sheets" | "postgres"
# kpiObligacionesPorVencer → migrado a PG (crisolweb.cartera_por_pagar), sin flag
DATA_SOURCE_VENTAS=postgres       # ventas en kpiDiario/snapshot — crisolweb.facturas
DATA_SOURCE_EGRESOS=postgres      # egresos en kpiDiario/snapshot — crisolweb.consecutivo_egresos
DATA_SOURCE_COBROS=sheets         # cobros — sin tabla PG confirmada aún
DATA_SOURCE_COTIZACIONES=sheets   # analisis_cotizaciones — pendiente
DATA_SOURCE_ORDENES=sheets        # ordenes_cumplidas — pendiente
DATA_SOURCE_CARTERA_CLI=sheets    # cartera_clientes — pendiente
